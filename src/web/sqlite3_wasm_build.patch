 import 'dart:js_interop';
 
-import 'package:web/web.dart';
+import 'package:web/web.dart' hide WebAssembly;
 
 import 'package:sqlite3/wasm.dart';
 
+/// Mirrors [LibSimpleTest.testSimpleQuery] in
+/// `src/android/simple-native-android/src/androidTest/.../LibSimpleTest.kt`.
+void runLibSimpleTest(WasmSqlite3 sqlite3) {
+  sqlite3.registerVirtualFileSystem(InMemoryFileSystem(), makeDefault: true);
+
+  final db = sqlite3.open('/lib_simple_test.db');
+  try {
+    db.execute(
+      "CREATE VIRTUAL TABLE t1 USING fts5(text, tokenize = 'simple')",
+    );
+
+    const insertText =
+        '示 (qí)，通「祇」，地神。《周礼·春官·大宗伯》：「大宗伯之职，掌建邦之天神人鬼地示之礼。」。汉·郑玄·注：「示，音祇，本或作祇。」';
+    db.execute('INSERT INTO t1 (text) VALUES (?)', [insertText]);
+
+    final rows = db.select(
+      "SELECT simple_highlight(t1, 0, '[', ']') FROM t1 WHERE text MATCH jieba_query('qi');",
+    );
+    print(rows.first.columnAt(0));
+  } finally {
+    db.dispose();
+  }
+}
+
 Future<void> main() async {
   final startIndexedDb = document.getElementById('start-idb')!;
   final startOpfs = document.getElementById('start-opfs')!;
   final startEncryption = document.getElementById('start-encryption')!;
+  final libSimpleButton = document.getElementById('start-libsimple-test');
 
   startIndexedDb.onClick.listen((_) async {
     startIndexedDb.remove();
     final sqlite3 = await WasmSqlite3.loadFromUrl(
-      Uri.parse('sqlite3.debug.wasm'),
+      Uri.parse('sqlite3.debug.wasm?v=2'),
     );
 
     print(sqlite3.version);
@@ -22,13 +47,16 @@
       makeDefault: true,
     );
 
-    sqlite3.open('/database')
-      ..execute('pragma user_version = 1')
-      ..execute('CREATE TABLE foo (bar INTEGER NOT NULL);')
-      ..execute('INSERT INTO foo (bar) VALUES (?)', [3])
-      ..close();
+    // sqlite3.open('/database')
+    //   ..execute('pragma user_version = 1')
+    //   ..execute('CREATE TABLE foo (bar INTEGER NOT NULL);')
+    //   ..execute('INSERT INTO foo (bar) VALUES (?)', [3])
+    //   ..close();
 
     final db = sqlite3.open('/database');
+
+    print(db.select("SELECT jieba_query('测试测试测试测试测试测试测试')"));
+
     print(db.select('SELECT * FROM foo'));
   });
 
@@ -61,4 +89,14 @@
     db.execute("pragma key = 'test';");
     print(db.select('SELECT * FROM foo'));
   });
+
+  if (libSimpleButton != null) {
+    libSimpleButton.onClick.listen((_) async {
+      libSimpleButton.remove();
+      final sqlite3 = await WasmSqlite3.loadFromUrl(
+        Uri.parse('sqlite3.debug.wasm?v=2'),
