Index: sqlite3/lib/src/wasm/wasi_snapshot_preview1_callbacks.dart
===================================================================
diff --git a/sqlite3/lib/src/wasm/wasi_snapshot_preview1_callbacks.dart b/sqlite3/lib/src/wasm/wasi_snapshot_preview1_callbacks.dart
new file mode 100644
--- /dev/null	(date 1775208461553)
+++ b/sqlite3/lib/src/wasm/wasi_snapshot_preview1_callbacks.dart	(date 1775208461553)
@@ -0,0 +1,166 @@
+// WASI preview1 imports for sqlite3.wasm, exposed like [DartBridgeCallbacks] via
+// [createJSInteropWrapper]. Implementation delegates to [wasd.WASI] after
+// [bindLinearMemory] wires linear memory (must run before the module's
+// `_initialize` export).
+
+import 'dart:js_interop';
+import 'dart:js_interop_unsafe';
+import 'dart:typed_data';
+
+import 'package:wasd/wasd.dart' as wasd;
+
+import 'js_interop/wasm.dart' as wasm_js;
+
+// ignore_for_file: non_constant_identifier_names
+
+final class _WasdInstanceNoExports implements wasd.Instance {
+  @override
+  wasd.Exports get exports => <String, wasd.ExportValue>{};
+}
+
+final class _SqliteMemoryForWasd implements wasd.Memory {
+  _SqliteMemoryForWasd(this._mem);
+
+  final wasm_js.Memory _mem;
+
+  @override
+  ByteBuffer get buffer => _mem.buffer.toDart;
+
+  @override
+  int grow(int delta) {
+    // Keep [wasm_js.Memory] unchanged: invoke WebAssembly.Memory.prototype.grow
+    // without declaring [grow] on the extension type.
+    return _mem.callMethod<JSNumber>('grow'.toJS, delta.toJS).toDartInt;
+  }
+}
+
+final class WasiSnapshotPreview1Callbacks {
+  final wasd.WASI _wasi = wasd.WASI();
+
+  late final Map<String, wasd.ImportValue> _preview1 =
+      _wasi.imports['wasi_snapshot_preview1']!;
+
+  /// Binds wasm linear memory for WASI syscalls. Call from
+  /// [WasmInstance.loadWithBeforeInitialize] after instantiation and before
+  /// `_initialize`.
+  void bindLinearMemory(wasm_js.Memory memory) {
+    _wasi.finalizeBindings(
+      _WasdInstanceNoExports(),
+      memory: _SqliteMemoryForWasd(memory),
+    );
+  }
+
+  int _call(String name, List<Object?> args) {
+    final v = _preview1[name];
+    if (v is! wasd.FunctionImportExportValue) return 52;
+    final r = v.ref(args);
+    if (r == null) return 0;
+    if (r is int) return r;
+    if (r is BigInt) return r.toInt();
+    return (r as num).toInt();
+  }
+
+  @JSExport('args_get')
+  int args_get(int argvPtr, int argvBufPtr) => _call('args_get', [argvPtr, argvBufPtr]);
+
+  @JSExport('args_sizes_get')
+  int args_sizes_get(int argcPtr, int argvBufSizePtr) =>
+      _call('args_sizes_get', [argcPtr, argvBufSizePtr]);
+
+  @JSExport('environ_get')
+  int environ_get(int environPtr, int environBufPtr) =>
+      _call('environ_get', [environPtr, environBufPtr]);
+
+  @JSExport('environ_sizes_get')
+  int environ_sizes_get(int environCountPtr, int environBufSizePtr) =>
+      _call('environ_sizes_get', [environCountPtr, environBufSizePtr]);
+
+  @JSExport('random_get')
+  int random_get(int bufPtr, int bufLen) => _call('random_get', [bufPtr, bufLen]);
+
+  @JSExport('fd_close')
+  int fd_close(int fd) => _call('fd_close', [fd]);
+
+  @JSExport('fd_fdstat_get')
+  int fd_fdstat_get(int fd, int fdstatPtr) =>
+      _call('fd_fdstat_get', [fd, fdstatPtr]);
+
+  @JSExport('fd_filestat_get')
+  int fd_filestat_get(int fd, int filestatPtr) =>
+      _call('fd_filestat_get', [fd, filestatPtr]);
+
+  @JSExport('fd_fdstat_set_flags')
+  int fd_fdstat_set_flags(int fd, int flags) =>
+      _call('fd_fdstat_set_flags', [fd, flags]);
+
+  @JSExport('fd_prestat_get')
+  int fd_prestat_get(int fd, int prestatPtr) =>
+      _call('fd_prestat_get', [fd, prestatPtr]);
+
+  @JSExport('fd_prestat_dir_name')
+  int fd_prestat_dir_name(int fd, int pathPtr, int pathLen) =>
+      _call('fd_prestat_dir_name', [fd, pathPtr, pathLen]);
+
+  @JSExport('fd_read')
+  int fd_read(int fd, int iovs, int iovsLen, int nreadPtr) =>
+      _call('fd_read', [fd, iovs, iovsLen, nreadPtr]);
+
+  @JSExport('fd_seek')
+  int fd_seek(int fd, Object? offset, int whence, int newOffsetPtr) =>
+      _call('fd_seek', [fd, offset, whence, newOffsetPtr]);
+
+  @JSExport('fd_write')
+  int fd_write(int fd, int iovs, int iovsLen, int nwrittenPtr) =>
+      _call('fd_write', [fd, iovs, iovsLen, nwrittenPtr]);
+
+  @JSExport('clock_time_get')
+  int clock_time_get(int clockId, Object? precision, int timePtr) =>
+      _call('clock_time_get', [clockId, precision, timePtr]);
+
+  @JSExport('sched_yield')
+  int sched_yield() => _call('sched_yield', const []);
+
+  @JSExport('path_filestat_get')
+  int path_filestat_get(
+    int fd,
+    int flags,
+    int pathPtr,
+    int pathLen,
+    int filestatPtr,
+  ) => _call('path_filestat_get', [fd, flags, pathPtr, pathLen, filestatPtr]);
+
+  @JSExport('path_open')
+  int path_open(
+    int fd,
+    int dirflags,
+    int pathPtr,
+    int pathLen,
+    int oflags,
+    Object? rightsBase,
+    Object? rightsInheriting,
+    int fdflags,
+    int openedFdPtr,
+  ) => _call('path_open', [
+    fd,
+    dirflags,
+    pathPtr,
+    pathLen,
+    oflags,
+    rightsBase,
+    rightsInheriting,
+    fdflags,
+    openedFdPtr,
+  ]);
+
+  @JSExport('poll_oneoff')
+  int poll_oneoff(int inPtr, int outPtr, int nsubscriptions, int neventsPtr) =>
+      _call('poll_oneoff', [inPtr, outPtr, nsubscriptions, neventsPtr]);
+
+  @JSExport('proc_exit')
+  void proc_exit(int code) {
+    final v = _preview1['proc_exit'];
+    if (v is wasd.FunctionImportExportValue) {
+      v.ref([code]);
+    }
+  }
+}
