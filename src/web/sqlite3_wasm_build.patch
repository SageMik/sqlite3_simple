diff --git a/sqlite3_wasm_build/src/cpp_exception_stubs.cc b/sqlite3_wasm_build/src/cpp_exception_stubs.cc
new file mode 100644
--- /dev/null	(date 1776097753954)
+++ b/sqlite3_wasm_build/src/cpp_exception_stubs.cc	(date 1776097753954)
@@ -0,0 +1,8 @@
+#include <cstddef>
+#include <cstdlib>
+
+extern "C" void *__cxa_allocate_exception(size_t thrown_size) { return malloc(thrown_size); }
+
+extern "C" void __cxa_free_exception(void *thrown_exception) { free(thrown_exception); }
+
+extern "C" void __cxa_throw(void *, void *, void (*)(void *)) { abort(); }
Index: sqlite3_wasm_build/src/CMakeLists.txt
IDEA additional info:
