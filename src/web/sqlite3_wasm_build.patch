diff --git a/sqlite3_wasm_build/src/CMakeLists.txt b/sqlite3_wasm_build/src/CMakeLists.txt
--- a/sqlite3_wasm_build/src/CMakeLists.txt	(revision 32eac80e47f4ca2822663730b6eeaa3c9b801833)
+++ b/sqlite3_wasm_build/src/CMakeLists.txt	(date 1776097766971)
@@ -1,11 +1,14 @@
 cmake_minimum_required(VERSION 3.24)
 
 set(PROJECT_NAME "sqlite3_web")
-project(${PROJECT_NAME} LANGUAGES C)
+project(${PROJECT_NAME} LANGUAGES C CXX)
 
-set(triple wasm32-unknown-wasi)
+set(triple wasm32-wasip1)
 set(wasi_sysroot "/usr/share/wasi-sysroot" CACHE PATH "Path to wasi sysroot")
 set(clang "clang" CACHE FILEPATH "Path to wasm-capable clang executable")
+set(clangxx "clang++" CACHE FILEPATH "Path to wasm-capable clang++ executable")
+
+include(simple_wasm.cmake)
 
 include(FetchContent)
 
@@ -44,7 +47,11 @@
     ${CMAKE_CURRENT_SOURCE_DIR}/helpers.c
     ${CMAKE_CURRENT_SOURCE_DIR}/external_objects.c
   )
-  set(flags -Wall -Wextra -Wno-unused-parameter -Wno-unused-function)
+  set(cpp_sources
+    ${CMAKE_CURRENT_SOURCE_DIR}/cpp_exception_stubs.cc
+    ${SIMPLE_WASM_SOURCES}
+  )
+  set(flags -Wall -Wextra -Wno-unused-parameter -Wno-unused-function -Wno-unused-variable -Wno-unused-but-set-variable)
 
   if(${crypto})
     list(APPEND sources "${sqlite3mc_SOURCE_DIR}/sqlite3mc_amalgamation.c")
@@ -70,23 +77,81 @@
     list(APPEND flags "-Oz" "-DNDEBUG" "-flto")
   endif()
 
-  add_custom_command(
-    OUTPUT ${clang_output}
-    COMMAND ${clang} --target=${triple} -std=c23
-      ${flags}
-      -o ${clang_output}
-      -I ${PROJECT_SOURCE_DIR} -I ${sqlite3_SOURCE_DIR}
-      -DSQLITE_ENABLE_SESSION
-      -DSQLITE_ENABLE_PREUPDATE_HOOK
-      -D_HAVE_SQLITE_CONFIG_H
-      -D__WASM__
+  set(common_compile_flags
+    --target=${triple}
+    -mcpu=generic
+    -fno-stack-protector -fno-stack-clash-protection
+    --sysroot ${wasi_sysroot}
+    -DSQLITE_ENABLE_SESSION
+    -DSQLITE_ENABLE_PREUPDATE_HOOK
+    -D_HAVE_SQLITE_CONFIG_H
+    -D__WASM__
+    ${flags}
+  )
+
+  # C 中间产物
+  set(c_objects)
+  foreach(source IN LISTS sources)
+    get_filename_component(source_name "${source}" NAME)
+    string(REPLACE "." "_" source_token "${source_name}")
+    set(object "${CMAKE_CURRENT_BINARY_DIR}/${name}_${source_token}.o")
+    add_custom_command(
+      OUTPUT ${object}
+      COMMAND ${clang}
+        ${common_compile_flags}
+        -x c -std=c23 -c
+        -I ${CMAKE_CURRENT_BINARY_DIR}
+        -I ${PROJECT_SOURCE_DIR}
+        -I ${sqlite3_SOURCE_DIR}
+        -o ${object}
+        ${source}
+      DEPENDS ${source}
+      VERBATIM
+    )
+    list(APPEND c_objects ${object})
+  endforeach()
+
+  # C++ 中间产物
+  set(cpp_objects)
+  foreach(source IN LISTS cpp_sources)
+    get_filename_component(source_name "${source}" NAME)
+    string(REPLACE "." "_" source_token "${source_name}")
+    set(object "${CMAKE_CURRENT_BINARY_DIR}/${name}_${source_token}.o")
+    add_custom_command(
+      OUTPUT ${object}
+      COMMAND ${clangxx}
+        ${common_compile_flags}
+        -fno-rtti
+        -DSQLITE_CORE
+        # -fwasm-exceptions -mllvm -wasm-use-legacy-eh=false # C++ 异常支持：https://github.com/WebAssembly/wasi-sdk/pull/606
+        -x c++ -std=c++14 -c
+        ${SIMPLE_WASM_CPP_ARGS}
+        -iquote ${sqlite3_SOURCE_DIR} # include <VERSION> 导致包含版本文件：https://github.com/nmap/nmap/issues/2747
+        -o ${object}
+        ${source}
+      DEPENDS ${source}
+      VERBATIM
+    )
+    list(APPEND cpp_objects ${object})
+  endforeach()
+
+  # 链接编译
+  add_custom_command(
+    OUTPUT ${clang_output}
+    COMMAND ${clangxx}
+      --target=${triple}
       -mcpu=generic
       -mexec-model=reactor
       -fno-stack-protector -fno-stack-clash-protection
       --sysroot ${wasi_sysroot}
-      ${sources}
+      -o ${clang_output}
+      ${c_objects}
+      ${cpp_objects}
+      # -lunwind # C++ 异常支持：https://github.com/WebAssembly/wasi-sdk/blob/main/CppExceptions.md
+      -lc++
+      -lc++abi
       @${CMAKE_CURRENT_BINARY_DIR}/required_symbols.txt
-    DEPENDS ${sources} required_symbols
+    DEPENDS ${c_objects} ${cpp_objects} required_symbols
     VERBATIM
   )
 
@@ -115,9 +180,12 @@
 base_sqlite3_target(sqlite3_opt false false)
 base_sqlite3_target(sqlite3mc false true)
 
+get_filename_component(_final_out_dir "${_repo_root}/src/web/out" ABSOLUTE)
+
 add_custom_target(output)
-add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3_opt.wasm ${PROJECT_SOURCE_DIR}/../out/sqlite3.wasm)
-add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3_debug.clang.wasm ${PROJECT_SOURCE_DIR}/../out/sqlite3.debug.wasm)
-add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3mc.wasm ${PROJECT_SOURCE_DIR}/../out/sqlite3mc.wasm)
+add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3_opt.wasm ${_final_out_dir}/sqlite3.wasm)
+add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3_debug.clang.wasm ${_final_out_dir}/sqlite3.debug.wasm)
+add_custom_command(TARGET output COMMAND ${CMAKE_COMMAND} -E copy ${CMAKE_BINARY_DIR}/sqlite3mc.wasm ${_final_out_dir}/sqlite3mc.wasm)
+add_custom_command(TARGET output POST_BUILD COMMAND ${CMAKE_COMMAND} -E echo "Final wasm outputs were copied to: ${_final_out_dir}")
 add_dependencies(output sqlite3_debug sqlite3_opt sqlite3mc)
 add_dependencies(output sqlite3_debug)
