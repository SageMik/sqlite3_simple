diff --git a/sqlite3_wasm_build/src/os_web.c b/sqlite3_wasm_build/src/os_web.c
--- a/sqlite3_wasm_build/src/os_web.c	(revision 32eac80e47f4ca2822663730b6eeaa3c9b801833)
+++ b/sqlite3_wasm_build/src/os_web.c	(date 1776097766977)
@@ -6,7 +6,12 @@
 #include "bridge.h"
 #include "sqlite3.h"
 
-int sqlite3_os_init(void) { return SQLITE_OK; }
+int sqlite3_simple_init(sqlite3* db, char** pzErrMsg,
+                        const sqlite3_api_routines* pApi);
+
+int sqlite3_os_init(void) {
+  return sqlite3_auto_extension((void*)sqlite3_simple_init);
+}
 
 int sqlite3_os_end(void) { return SQLITE_OK; }
 
Index: sqlite3_wasm_build/src/simple_wasm.cmake
